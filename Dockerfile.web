# Generic build for any Next.js static-export app in the monorepo.
# Build context MUST be the monorepo root (workspace deps live in packages/).
#   docker build -f Dockerfile.web --build-arg APP=app .
ARG APP

FROM node:22-alpine AS builder
RUN corepack enable
WORKDIR /repo

# API base URL is baked at build time (static export). The browser reaches it,
# so the default targets the host-published API port.
ARG NEXT_PUBLIC_API_URL=http://localhost:3001
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

# Copy the whole workspace (node_modules/target/etc. excluded via .dockerignore)
COPY . .
RUN pnpm install --frozen-lockfile

ARG APP
RUN pnpm turbo run build --filter=${APP}

# --- serve static output with nginx ---
FROM nginx:alpine AS runner
ARG APP
COPY --from=builder /repo/apps/${APP}/out /usr/share/nginx/html
COPY nginx.web.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
