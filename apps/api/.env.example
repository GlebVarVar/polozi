RUST_LOG=<string> # tracing EnvFilter, e.g. info,polozi_api=debug
DATABASE_URL=<url> # postgres://user:pass@host:port/db
PORT=<number> # defaults to 3001 if unset
JWT_SECRET=<string>
ADMIN_USERNAME=<string> # seeded admin, defaults to "admin"
ADMIN_PASSWORD=<string> # seeded admin password, defaults to "admin123"
TEST_DATABASE_URL=<url> # e2e tests only; falls back to DATABASE_URL
